# ═══════════════════════════════════════════════════════════════════════════════
# vf-crowd-control.env.example
# Visual FaQtory Crowd Control Server — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Used by the systemd unit or manual launch.
# Copy to vf-crowd-control.env and adjust.
#
# Part of QonQrete Visual FaQtory v0.8.4-beta

# ── Required ─────────────────────────────────────────────────────────────────
# Bearer token for the /api/next pop endpoint (generator uses this)
VF_CROWD_TOKEN=CHANGE_ME_LONG_RANDOM_STRING

# ── Server bind ──────────────────────────────────────────────────────────────
VF_CROWD_HOST=0.0.0.0
VF_CROWD_PORT=8808
VF_CROWD_PREFIX=/visuals

# ── Public URL (used for QR code generation) ─────────────────────────────────
VF_CROWD_PUBLIC_URL=https://wonq.tv/visuals

# ── Database ─────────────────────────────────────────────────────────────────
VF_CROWD_DB_PATH=worqspace/crowdcontrol.sqlite3

# ── Filtering ────────────────────────────────────────────────────────────────
VF_CROWD_BADWORDS=worqspace/badwords.txt
VF_CROWD_MAX_CHARS=300
VF_CROWD_RATE_LIMIT=600
VF_CROWD_MAX_QUEUE=100

# ── Dev only ─────────────────────────────────────────────────────────────────
# VF_CROWD_ALLOW_NO_TOKEN=true
