# ═══════════════════════════════════════════════════════════════════════════════
# vf-obs-watcher-srt-endpoints.env.example
# Visual FaQtory SRT A/B Playout — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy to vf-obs-watcher-srt-endpoints.env and adjust.
# Or export these vars before running the script.
# Or set VF_SRT_ENV=/path/to/your.env to load a custom location.
#
# Part of QonQrete Visual FaQtory v0.5.9-beta

# ── OBS WebSocket ────────────────────────────────────────────────────────────
# Set OBS_AUTOSWAP=0 to disable OBS switching (SRT endpoints still active)
OBS_AUTOSWAP=1
OBS_WS_HOST=10.20.30.12
OBS_WS_PORT=4455
OBS_WS_PASSWORD=YourOBSPassword
OBS_SCENE_NAME=Live Visuals
OBS_SOURCE_A=Live-Visuals-A
OBS_SOURCE_B=Live-Visuals-B

# ── SRT Endpoints ────────────────────────────────────────────────────────────
# SRT_BIND_IP: address ffmpeg listens on (0.0.0.0 for all interfaces)
# SRT_PUBLIC_IP: address the remote OBS caller connects to (e.g. ZeroTier IP)
SRT_BIND_IP=0.0.0.0
SRT_PUBLIC_IP=10.20.30.22
SRT_PORT_A=9998
SRT_PORT_B=9999
SRT_LATENCY=20

# ── Encoding ─────────────────────────────────────────────────────────────────
OUT_WIDTH=1280
OUT_HEIGHT=720
OUT_FPS=30
ENC_PRESET=veryfast
ENC_BITRATE=6000k
ENC_BUFSIZE=12000k

# ── Timing ───────────────────────────────────────────────────────────────────
# How long to prewarm the new slot before disabling the old one
WARMUP_SEC=1.2

# ── Paths ────────────────────────────────────────────────────────────────────
# VF_WATCH_DIR: override auto-detection from config YAML
# VF_WATCH_DIR=/path/to/visual-faqtory/run/videos_interpolated
# VF_PLAYOUT_DIR: where slot files + state are kept
# VF_PLAYOUT_DIR=/path/to/visual-faqtory/run/obs
# VF_PYTHON_BIN: python with obsws-python installed
# VF_PYTHON_BIN=/path/to/visual-faqtory/.venv/bin/python
# VF_FFMPEG_BIN: path to ffmpeg binary
# VF_FFMPEG_BIN=ffmpeg
