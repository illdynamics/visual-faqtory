# ═══════════════════════════════════════════════════════════════════════════════
# vf-obs-watcher-srt-endpoints.env.example
# Visual FaQtory SRT A/B Playout — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy to vf-obs-watcher-srt-endpoints.env and adjust.
# Or export these vars before running the script.
# Or set VF_SRT_ENV=/path/to/your.env to load a custom location.
#
# Part of Visual FaQtory v0.9.3-beta

# ── OBS WebSocket ────────────────────────────────────────────────────────────
# Set OBS_AUTOSWAP=0 to disable OBS switching (SRT endpoints still active)
OBS_AUTOSWAP=1
OBS_WS_HOST=10.20.30.12
OBS_WS_PORT=4455
OBS_WS_PASSWORD=YourOBSPassword
OBS_SCENE_NAME=Live Visuals
OBS_SOURCE_A=Live-Visuals-A
OBS_SOURCE_B=Live-Visuals-B

# ── SRT Endpoints ────────────────────────────────────────────────────────────
# SRT_BIND_IP: address ffmpeg listens on (0.0.0.0 for all interfaces)
# SRT_PUBLIC_IP: address the remote OBS caller connects to (e.g. ZeroTier IP)
SRT_BIND_IP=0.0.0.0
SRT_PUBLIC_IP=10.20.30.22
SRT_PORT_A=9998
SRT_PORT_B=9999
SRT_LATENCY=20

# ── Encoding ─────────────────────────────────────────────────────────────────
OUT_WIDTH=1280
OUT_HEIGHT=720
OUT_FPS=30
ENC_PRESET=veryfast
ENC_BITRATE=6000k
ENC_BUFSIZE=12000k

# ── Timing ───────────────────────────────────────────────────────────────────
# How long to prewarm the new slot before disabling the old one
WARMUP_SEC=1.2
# File readiness guard before a clip is swapped live
READY_TIMEOUT_SEC=60
READY_POLL_INTERVAL_SEC=1
READY_STABLE_POLLS=2
# Startup preload: copy newest existing watched .mp4 into both slots on boot
PRELOAD_EXISTING_ON_START=1

# ── Paths / Config discovery ─────────────────────────────────────────────────
# VF_CONFIG_FILE: explicit active config override. If unset, the watcher prefers
# worqspace/config.yaml and only falls back to worqspace/config-live.yaml when
# config.yaml is absent.
# VF_CONFIG_FILE=/path/to/visual-faqtory/worqspace/config.yaml
#
# VF_WATCH_DIR: override auto-detection from the active config YAML.
# If unset, the watcher derives:
#   <output_dir>/videos_interpolated  when finalizer.per_cycle_interpolation=true
#   <output_dir>/videos               otherwise
# VF_WATCH_DIR=/path/to/visual-faqtory/run/videos_interpolated
# Relative VF_WATCH_DIR values are resolved from the repo base too.
#
# VF_PLAYOUT_DIR: where slot files + state are kept
# VF_PLAYOUT_DIR=/path/to/visual-faqtory/run/obs
#
# VF_PYTHON_BIN: python with obsws-python + PyYAML installed
# VF_PYTHON_BIN=/path/to/visual-faqtory/.venv/bin/python
#
# VF_CONFIG_PYTHON_BIN: optional different python for YAML config parsing
# VF_CONFIG_PYTHON_BIN=/usr/bin/python3
#
# VF_FFMPEG_BIN / VF_FFPROBE_BIN / VF_INOTIFYWAIT_BIN: tool paths
# VF_FFMPEG_BIN=ffmpeg
# VF_FFPROBE_BIN=ffprobe
# VF_INOTIFYWAIT_BIN=inotifywait

# ── Optional watcher helpers ─────────────────────────────────────────────────
# DEDUP_WINDOW_SEC: ignore duplicate inotify events for the same file within N seconds
DEDUP_WINDOW_SEC=2

# HEALTHCHECK_INTERVAL_SEC: restart dead ffmpeg slots + recreate missing watch dir
HEALTHCHECK_INTERVAL_SEC=5
# WATCH_RETRY_SEC: wait before restarting inotify after a watch-dir disappearance
WATCH_RETRY_SEC=2
